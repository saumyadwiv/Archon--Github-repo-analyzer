# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/archon

# Redis (used by BullMQ + Socket.IO adapter)
# On Render, set REDIS_URL to your Key Value instance's Internal Redis URL
# (Connect menu on the instance's page) — Render doesn't expose separate
# host/port/password fields. Locally with `docker compose up`, leave
# REDIS_URL unset and use the host/port below instead.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Set to true only on free-tier hosts with no separate Background Worker
# service (e.g. Render's free plan) — runs the BullMQ analysis consumer
# inside this same process instead of a standalone `npm run worker`.
RUN_WORKER_INLINE=false

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_too_to_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Session cookie
COOKIE_SECRET=change_this_cookie_secret

# Gemini AI (used in Part 4)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# Repo cloning
CLONE_TMP_DIR=/tmp/archon-repos
MAX_REPO_SIZE_MB=250

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
